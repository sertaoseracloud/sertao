{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Glossário técnico usado pela pipeline de tradução EN→PT-BR (Claude Haiku) para preservar terminologia de cloud computing. Lido como system prompt pelo Translator. Atualizar após cada PR de sync que exige correção editorial.",
  "version": "1.0.0",
  "last_updated": "2026-04-22",
  "preserve_as_is": [
    "AWS", "Azure", "GCP", "Google Cloud", "Google Cloud Platform",
    "EC2", "Lambda", "S3", "SNS", "SQS", "DynamoDB", "RDS", "Aurora",
    "ECS", "EKS", "Fargate", "CloudFront", "CloudWatch", "CloudFormation",
    "IAM", "VPC", "Route 53", "API Gateway", "Step Functions", "EventBridge",
    "Kinesis", "Redshift", "Athena", "Glue",
    "Service Bus", "Event Grid", "Event Hubs", "Functions", "App Service",
    "AKS", "Cosmos DB", "Blob Storage", "Application Insights",
    "Pub/Sub", "BigQuery", "Cloud Run", "Cloud Functions", "GKE",
    "Firestore", "Spanner", "Dataflow", "Dataproc",
    "Kubernetes", "Docker", "Terraform", "Pulumi", "Ansible", "Helm",
    "Redis", "Postgres", "PostgreSQL", "MySQL", "MongoDB", "Cassandra",
    "Kafka", "RabbitMQ", "gRPC", "GraphQL", "REST",
    "serverless", "container", "pod", "node", "cluster", "microservices",
    "endpoint", "payload", "webhook", "trigger", "queue", "topic",
    "subscription", "producer", "consumer", "broker", "DLQ",
    "OAuth", "OIDC", "JWT", "SAML", "mTLS", "TLS", "SSL",
    "CORS", "CSP", "DNS", "CDN", "WAF", "DDoS",
    "SLA", "SLO", "SLI", "KPI", "MTTR", "MTBF", "RPO", "RTO",
    "CI", "CD", "CI/CD", "DevOps", "SRE", "GitOps",
    "monorepo", "polyrepo", "multi-tenant", "single-tenant",
    "stateless", "stateful", "immutable", "idempotent",
    "OpenTelemetry", "Prometheus", "Grafana", "Jaeger", "Datadog",
    "GitHub", "GitLab", "Bitbucket", "npm", "pnpm", "yarn",
    "TypeScript", "JavaScript", "Node.js", "Python", "Go", "Rust",
    "YAML", "JSON", "TOML", "XML", "HTML", "CSS", "Markdown",
    "IDE", "CLI", "SDK", "API", "REST", "SSR", "SSG", "CSR",
    "Anthropic", "Claude", "OpenAI", "GPT"
  ],
  "prefer_en_over_pt": {
    "deploy": "manter 'deploy' — não traduzir como 'implantação'",
    "deployment": "manter 'deployment'",
    "pipeline": "manter 'pipeline' — não traduzir como 'esteira'",
    "build": "manter 'build'",
    "rollout": "manter 'rollout'",
    "rollback": "manter 'rollback'",
    "runtime": "manter 'runtime' — não 'tempo de execução'",
    "throughput": "manter 'throughput'",
    "latency": "aceitável traduzir como 'latência' (bem consolidado em PT)",
    "idempotent": "'idempotente' (forma PT padrão)",
    "stateless": "manter 'stateless'",
    "stateful": "manter 'stateful'",
    "endpoint": "manter 'endpoint'",
    "payload": "manter 'payload'",
    "webhook": "manter 'webhook'",
    "queue": "manter 'queue' em contexto técnico; 'fila' apenas em linguagem cotidiana fora de código",
    "topic": "manter 'topic' em contexto pub/sub; 'tópico' apenas em linguagem cotidiana",
    "fan-out": "manter 'fan-out' hifenizado",
    "fan-in": "manter 'fan-in' hifenizado",
    "at-least-once": "manter 'at-least-once' hifenizado",
    "at-most-once": "manter 'at-most-once' hifenizado",
    "exactly-once": "manter 'exactly-once' hifenizado",
    "scale out": "manter 'scale out' ou 'escalar horizontalmente'",
    "scale up": "manter 'scale up' ou 'escalar verticalmente'",
    "cold start": "manter 'cold start'",
    "warm start": "manter 'warm start'",
    "blast radius": "traduzir como 'raio de impacto'",
    "bounded context": "traduzir como 'contexto limitado' (DDD consolidado em PT)",
    "shared fate": "traduzir como 'destino compartilhado'",
    "failure domain": "traduzir como 'domínio de falha'",
    "dead letter queue": "manter 'dead letter queue' ou sigla DLQ"
  },
  "translate_with_care": {
    "eventual consistency": "consistência eventual",
    "strong consistency": "consistência forte",
    "read-after-write": "manter 'read-after-write'",
    "write-ahead log": "manter 'write-ahead log' ou WAL",
    "load balancer": "aceitável traduzir como 'balanceador de carga' ou manter",
    "rate limit": "aceitável 'limite de taxa' ou manter",
    "throttling": "manter 'throttling'",
    "observability": "'observabilidade' (consolidado em PT)",
    "event-driven": "'orientado a eventos' OU manter 'event-driven'",
    "data plane": "'plano de dados' OU manter 'data plane'",
    "control plane": "'plano de controle' OU manter 'control plane'"
  },
  "never_translate": [
    "Blocos de código (```…```) — preservar 100% idêntico",
    "Código inline (`…`) — preservar 100% idêntico",
    "URLs — preservar verbatim",
    "Nomes próprios — preservar verbatim",
    "Citações diretas em inglês entre aspas — preservar em EN",
    "Nomes de arquivo e paths (.ts, .yaml, .tf, src/components/) — preservar",
    "Variáveis de ambiente e secrets (ANTHROPIC_API_KEY) — preservar",
    "Comandos de terminal — preservar"
  ],
  "style_notes": [
    "Público-alvo: desenvolvedor brasileiro técnico, intermediário-a-sênior, acostumado com anglicismos de cloud.",
    "Preferir PT-BR informal mas profissional (você, não vossa mercê nem 2ª pessoa clássica).",
    "Evitar cognatos falsos forçados ('realize' → 'realizar' pode ser 'perceber' no contexto certo).",
    "Manter acordo ortográfico pós-2009 (rigorosamente).",
    "Datas: formato PT-BR (21 de abril de 2026), não US.",
    "Unidades: preservar (GB, ms, req/s) — mesmo em PT.",
    "Números: vírgula como decimal em contexto de prosa (R$5,10); ponto aceitável em contexto técnico (5.10)."
  ]
}
