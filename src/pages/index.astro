---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Início" description="Blog sobre cloud computing em português — O Sertão será Cloud.">
  <Header slot="header" />

  <div class="stage">
    <!-- Hero -->
    <section style="padding: 64px 0 48px; max-width: 720px;">
      <p style="font-family:'Chakra Petch',sans-serif;font-size:11px;letter-spacing:0.28em;text-transform:uppercase;color:var(--nucleo-eletrico);margin-bottom:16px;">
        ☁ Cloud Computing · PT-BR
      </p>
      <h1 style="font-size:clamp(44px,4.2vw,68px);font-weight:700;line-height:0.96;letter-spacing:-0.015em;color:#E9FBFF;margin:0 0 24px;">
        O Sertão<br/><em style="color:var(--nucleo-eletrico);font-style:italic;">será Cloud</em>
      </h1>
      <p style="font-size:18px;color:var(--texto-secundario);max-width:58ch;font-weight:300;line-height:1.6;">
        Tutoriais, análises e opinião sobre cloud computing — direto do Sertão pra nuvem.
      </p>
    </section>

    <!-- Recent posts grid -->
    {recentPosts.length > 0 ? (
      <section>
        <p style="font-family:'Chakra Petch',sans-serif;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--texto-secundario);margin-bottom:24px;">
          Posts recentes
        </p>
        <div class="cards">
          {recentPosts.map((post) => (
            <a href={`/posts/${post.id.replace(/\.[^.]+$/, '')}`} class="card" style="text-decoration:none;">
              <div class={`card-media p-${post.data.tags?.[0] ?? 'arq'}`}></div>
              <div class="card-body">
                <div class="tag-row" style="margin-bottom:8px;">
                  {post.data.tags?.slice(0,2).map((tag: string) => (
                    <span class="tag"><span class="hash">#</span>{tag}</span>
                  ))}
                </div>
                <h3>{post.data.title}</h3>
                <p class="card-meta">
                  {new Date(post.data.pubDate).toLocaleDateString('pt-BR', { dateStyle: 'medium' })}
                </p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : (
      <section style="padding:48px 0;text-align:center;border:1px dashed var(--hairline);">
        <p style="color:var(--texto-secundario);font-family:'JetBrains Mono',monospace;font-size:13px;">
          // posts chegam via pipeline dev.to → Phase 2
        </p>
      </section>
    )}
  </div>

  <Footer slot="footer" />
</BaseLayout>
